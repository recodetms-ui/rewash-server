# ═══════════════════════════════════════════════════════════════
#  RE-WASH Server — إعدادات البيئة
#  انسخ هذا الملف باسم .env واملأ القيم الحقيقية
#  ⚠️ لا ترفع .env على GitHub أبداً (موجود في .gitignore)
# ═══════════════════════════════════════════════════════════════

# المنفذ الذي يعمل عليه الخادم
PORT=3000

# بيئة التشغيل: production على الـ VPS، development للتجربة
NODE_ENV=production

# ── قاعدة البيانات PostgreSQL ──
DATABASE_URL=postgresql://rewash:CHANGE_THIS_PASSWORD@localhost:5432/rewash_db

# ── أسرار التوقيع (ولّد قيم عشوائية قوية — انظر التعليمات) ──
# سر توقيع رموز الدخول (JWT) — 64 حرف عشوائي على الأقل
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_64_CHARS_MINIMUM

# مدة صلاحية رمز الدخول للوحة التحكم
JWT_EXPIRES_IN=7d

# ── المفتاح العام للتراخيص (نفس المفتاح في license-verify.js) ──
# يُستخدم للتحقق من التراخيص على الخادم أيضاً
LICENSE_PUBLIC_KEY=AuKMXUJ0JiBd7vuarsDqwDEUUNwOj+vA/VPu8DDryYI=

# ── النطاق المسموح له بالاتصال (CORS) — لوحة التحكم ──
ALLOWED_ORIGINS=https://recode-systems.com,https://www.recode-systems.com

# ── مفتاح الإدارة الرئيسي (للمطور فقط — لإنشاء حسابات المالكين) ──
ADMIN_API_KEY=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_STRING
